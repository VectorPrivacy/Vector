<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext HTTP to localhost only (for the media server that provides
     Range request support to <video> and <audio> elements). All other hosts
     remain HTTPS-only. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
